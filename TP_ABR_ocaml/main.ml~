let rec remove d key =
  match d with
  | Empty -> failwith "Key is not in the dict"
  | Node(data, Empty, right) -> (data, right)
  | Node(data, left, right) ->
     let k, v = data in
     let prev_data, new_left = remove left key in
     if k = key then
       (data, Node(prev_data, new_left, right))
     else if key < k then
       (data, Node(new_left, right))
     else
       (data, Node(new_left, right))
           
