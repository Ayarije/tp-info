let rec insert d key value =
  match d with
  | Empty -> Node((key, value), Empty, Empty)
  | Node(data, left, right) ->
     let k, v = data in
     if k = key then
       failwith "Key already exists"
     else if key < k then
       Node(data, insert left key value, right)
     else
       Node(data, left, insert right key value);;

